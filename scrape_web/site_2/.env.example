# Copy to ``.env`` and adjust.

LOG_FILE=log/site_2.log
SCRAPE_SITE2_URL=https://www.liuhjgled.com/products
SCRAPE_SITE2_HOME=/path/to/output/home
SCRAPE_SITE2_IMAGES=/path/to/output/home/images
SCRAPE_SITE2_IDENTIFIER_START=100001

# Max product rows to process in scrape_product (omit for no limit)
SCRAPE_SITE2_MAX_ITERATION=100
